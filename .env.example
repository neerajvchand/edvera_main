# Frontend app (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Frontend app (optional metadata)
VITE_SUPABASE_PROJECT_ID=
VITE_PUBLIC_SITE_URL=

# Supabase Edge Functions (required when deploying/running functions)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LOVABLE_API_KEY=

# Shared admin secret for server/cron jobs: send as X-Admin-API-Key when calling
# Supabase Edge Function run-all-engines (POST JSON body must include "district_id").
# Also used by detect-board-meetings and similar protected functions.
ADMIN_API_KEY=

# AI Insights (Anthropic Claude API — used by generate-insights Edge Function)
ANTHROPIC_API_KEY=

# Python agent (FastAPI) — server-side only; do not use VITE_* prefixes
API_SECRET_KEY=

# Supabase Edge Function `agent-daily-brief` proxies to the agent using:
AGENT_URL=
AGENT_API_KEY=
